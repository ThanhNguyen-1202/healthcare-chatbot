APP_NAME=healthcare-chatbot
APP_ENV=docker
APP_HOST=0.0.0.0
APP_PORT=8000

MONGO_URI=mongodb://mongo:27017
MONGO_DB=Chatbox_Healthcare

GEMINI_API_KEY=key_for_docker_environment
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_EXTRACTOR_MODEL=gemini-3.1-flash-lite
GEMINI_TRANSLATION_MODEL=gemini-3.1-flash-lite

CORS_ORIGINS=["http://localhost:5500","http://127.0.0.1:5500","http://localhost:8000","http://localhost:8080"]
CHAT_RATE_LIMIT=20/minute
PREDICT_RATE_LIMIT=30/minute
